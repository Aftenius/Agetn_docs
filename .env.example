DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Уровень логов бэкенда (INFO, DEBUG, …): время запросов к LLM и этапы analyze/generate
# LOG_LEVEL=INFO

# Опционально:
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# RAG: эмбеддинги OpenAI-compatible (если не задано — поиск по ключевым словам)
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# Папка данных компании (абсолютный путь). По умолчанию: data/workspace/default
# DOCS_AGENT_WORKSPACE=

# Docker: скопируйте файл в .env, укажите ключ, затем из корня репозитория:
#   docker compose up --build
# Откройте http://localhost:8000 (единая точка входа: UI и /api)
